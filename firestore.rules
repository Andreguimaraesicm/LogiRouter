rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---- Global Safety Net ----
    match /{document=**} {
      allow read, write: if false;
    }

    // ---- Helper Functions ----
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isMaster() {
      return hasRole('master') || request.auth.token.email == 'andreguimaraesicm@gmail.com';
    }

    function isManager() {
      return isMaster() || hasRole('manager');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---- Entity Validators ----
    function isValidUser(data) {
      return data.username is string && data.username.size() < 100 &&
             data.role in ['master', 'manager', 'driver'] &&
             data.displayName is string;
    }

    function isValidRoute(data) {
      return data.driverId is string && data.vehicleId is string &&
             data.status in ['pending', 'in_progress', 'completed'];
    }

    // ---- Collection Rules ----
    match /{allPaths=**} {
      allow read, write: if true; // Temporarily allow for development due to custom auth bypass
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isManager());
      allow list: if isManager();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if (isMaster() || (request.auth.uid == userId && isValidUser(incoming()))) && 
                    (incoming().role == existing().role || isMaster()); // Only master can change roles
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /routes/{routeId} {
      allow read: if isSignedIn() && (isManager() || existing().driverId == request.auth.uid);
      allow create: if isManager() && isValidRoute(incoming());
      allow update: if (isManager() && isValidRoute(incoming())) ||
                    (isSignedIn() && existing().driverId == request.auth.uid && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['status', 'stops']) && 
                     isValidRoute(incoming()));
      allow delete: if isManager();
    }

    match /settings/global {
      allow read: if true;
      allow write: if true; // allow write for now as the app uses a custom bypass login
    }
  }
}
